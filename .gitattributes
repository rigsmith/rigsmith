# Normalize everything to LF in the repository AND in working trees, so the
# parity goldens (core/testdata/parity/**) and other byte-compared fixtures are
# identical on Windows checkouts (git for Windows defaults core.autocrlf=true).
* text=auto eol=lf

# Binary-ish assets: never translate.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
